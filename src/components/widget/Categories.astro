---
import I18nKey from "../../i18n/i18nKey";
import { i18n } from "../../i18n/translation";
import { getCategoryTree } from "../../utils/content-utils";
import WidgetLayout from "./WidgetLayout.astro";

const categoryTree = await getCategoryTree();

interface Props {
	class?: string;
	style?: string;
}
const className = Astro.props.class;
const style = Astro.props.style;
---

<WidgetLayout name={i18n(I18nKey.categories)} id="categories"
              class={className} style={style}
>
    {categoryTree.map((cat) =>
        cat.children.length > 0 ? (
            <div class="category-group">
                <div class="flex items-center w-full h-10 rounded-lg
                    hover:bg-[var(--btn-plain-bg-hover)] active:bg-[var(--btn-plain-bg-active)]
                    transition-all">
                    <a href={cat.url}
                       class="flex-1 flex items-center h-full px-2
                           text-neutral-700 dark:text-neutral-300
                           hover:text-[var(--primary)] dark:hover:text-[var(--primary)]
                           transition-all overflow-hidden">
                        <span class="font-medium">{cat.name}</span>
                        <span class="text-sm text-neutral-400 dark:text-neutral-500 ml-1">({cat.count})</span>
                    </a>
                    <button type="button" class="cat-toggle flex items-center justify-center w-8 h-8
                        text-neutral-400 dark:text-neutral-500 transition-all"
                        data-target={`sub-${cat.name}`}>
                        <svg class="accordion-arrow w-4 h-4 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M9 18l6-6-6-6"/>
                        </svg>
                    </button>
                </div>
                <div id={`sub-${cat.name}`} class="subcategory-list pl-2">
                    {cat.children.map((sub) =>
                        <a href={sub.url}
                           class="flex items-center gap-2 w-full h-9 px-2 rounded-lg
                               text-sm text-neutral-600 dark:text-neutral-400
                               hover:bg-[var(--btn-plain-bg-hover)] active:bg-[var(--btn-plain-bg-active)]
                               hover:text-[var(--primary)] dark:hover:text-[var(--primary)]
                               transition-all"
                           aria-label={`View posts in ${cat.name}/${sub.name}`}>
                            <span class="text-neutral-400 dark:text-neutral-500">&rsaquo;</span>
                            <span>{sub.name}</span>
                            <span class="text-xs text-neutral-400 dark:text-neutral-500">({sub.count})</span>
                        </a>
                    )}
                </div>
            </div>
        ) : (
            <a href={cat.url}
               class="flex items-center w-full h-10 px-2 rounded-lg
                   text-neutral-700 dark:text-neutral-300
                   hover:bg-[var(--btn-plain-bg-hover)] active:bg-[var(--btn-plain-bg-active)]
                   hover:text-[var(--primary)] dark:hover:text-[var(--primary)]
                   transition-all"
               aria-label={`View all posts in the ${cat.name} category`}>
                <span class="font-medium">{cat.name}</span>
                <span class="text-sm text-neutral-400 dark:text-neutral-500 ml-1">({cat.count})</span>
            </a>
        )
    )}
</WidgetLayout>

<script>
    const toggleCategoryList = (btn: HTMLElement) => {
        const targetId = btn.dataset.target;
        if (!targetId) return;

        const list = document.getElementById(targetId);
        if (!list) return;

        const isOpen = list.classList.contains('open');
        if (isOpen) {
            const currentHeight = list.scrollHeight;
            list.style.maxHeight = `${currentHeight}px`;
            requestAnimationFrame(() => {
                list.style.maxHeight = '0';
            });
            list.classList.remove('open');
        } else {
            list.style.maxHeight = '0';
            list.classList.add('open');
            requestAnimationFrame(() => {
                list.style.maxHeight = `${list.scrollHeight}px`;
            });
            list.addEventListener('transitionend', () => {
                if (list.classList.contains('open')) {
                    list.style.maxHeight = 'none';
                }
            }, { once: true });
        }

        const arrow = btn.querySelector('.accordion-arrow');
        arrow?.classList.toggle('rotate-90', !isOpen);
    };

    if (!document.documentElement.dataset.categoryToggleBound) {
        document.addEventListener('click', (event) => {
            const target = event.target;
            if (!(target instanceof Element)) return;

            const btn = target.closest('.cat-toggle');
            if (!(btn instanceof HTMLElement)) return;

            toggleCategoryList(btn);
        });

        document.documentElement.dataset.categoryToggleBound = 'true';
    }
</script>

<style>
    .subcategory-list {
        max-height: 0;
        overflow: hidden;
        transition: max-height 0.25s ease;
    }
    .rotate-90 {
        transform: rotate(90deg);
    }
</style>
