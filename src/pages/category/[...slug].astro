---
import PostCard from "@components/PostCard.astro";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import { getSortedPosts } from "@utils/content-utils";
import { formatDateToYYYYMMDD } from "@utils/date-utils";
import { getPostUrlBySlug } from "@utils/url-utils";
import { Icon } from "astro-icon/components";

export async function getStaticPaths() {
	const allPosts = await getSortedPosts();

	const categories = new Map<string, Set<string>>();

	for (const post of allPosts) {
		const cat = post.data.category?.trim();
		if (!cat) continue;

		if (!categories.has(cat)) {
			categories.set(cat, new Set());
		}

		const sub = post.data.subcategory?.trim();
		if (sub) {
			categories.get(cat)?.add(sub);
		}
	}

	const paths = [];

	for (const [cat, subs] of categories) {
		paths.push({
			params: { slug: cat },
			props: { category: cat, subcategory: null },
		});

		for (const sub of subs) {
			paths.push({
				params: { slug: `${cat}/${sub}` },
				props: { category: cat, subcategory: sub },
			});
		}
	}

	return paths;
}

interface Props {
	category: string;
	subcategory: string | null;
}

const { category, subcategory } = Astro.props;
const allPosts = await getSortedPosts();

const filteredPosts = allPosts.filter((post) => {
	if (post.data.category?.trim() !== category) return false;
	if (subcategory && post.data.subcategory?.trim() !== subcategory)
		return false;
	return true;
});

const title = subcategory ? `${category} / ${subcategory}` : category;

// Group posts by year for list view
const groupedByYear = filteredPosts.reduce(
	(acc, post) => {
		const year = post.data.published.getFullYear();
		if (!acc[year]) acc[year] = [];
		acc[year].push(post);
		return acc;
	},
	{} as Record<number, typeof filteredPosts>,
);
const years = Object.keys(groupedByYear)
	.map(Number)
	.sort((a, b) => b - a);
---

<MainGridLayout title={title}>
    <category-view-toggle>
    <div class="flex justify-between items-center mb-4">
        <h1 class="text-2xl font-bold text-90 transition">{title}</h1>
        <div class="flex gap-1">
            <button data-view="card" class="view-btn p-2 rounded-lg transition hover:bg-[var(--btn-plain-bg-hover)]"
                    aria-label="Card view"
                    style="color: var(--primary); background-color: var(--btn-plain-bg-hover);">
                <Icon name="material-symbols:grid-view-rounded" class="text-xl" />
            </button>
            <button data-view="list" class="view-btn p-2 rounded-lg transition hover:bg-[var(--btn-plain-bg-hover)]"
                    aria-label="List view">
                <Icon name="material-symbols:list-rounded" class="text-xl" />
            </button>
        </div>
    </div>

    <!-- Card View -->
    <div data-panel="card" class="transition flex flex-col rounded-[var(--radius-large)] bg-[var(--card-bg)] py-1 md:py-0 md:bg-transparent md:gap-4 mb-4">
        {filteredPosts.map((entry, i) => (
            <PostCard
                entry={entry}
                title={entry.data.title}
                tags={entry.data.tags}
                category={entry.data.category}
                published={entry.data.published}
                updated={entry.data.updated}
                url={getPostUrlBySlug(entry.slug)}
                image={entry.data.image}
                description={entry.data.description}
                draft={entry.data.draft}
                class:list="onload-animation"
                style={`animation-delay: calc(var(--content-delay) + ${i * 50}ms);`}
            />
        ))}
    </div>

    <!-- List View -->
    <div data-panel="list" class="hidden card-base px-8 py-6 mb-4">
        {years.map((year) => (
            <div>
                <div class="flex flex-row w-full items-center h-[3.75rem]">
                    <div class="w-[15%] md:w-[10%] transition text-2xl font-bold text-right text-75">
                        {year}
                    </div>
                    <div class="w-[15%] md:w-[10%]">
                        <div class="h-3 w-3 bg-none rounded-full outline outline-[var(--primary)] mx-auto
                            -outline-offset-[2px] z-50 outline-3"></div>
                    </div>
                    <div class="w-[70%] md:w-[80%] transition text-left text-50">
                        {groupedByYear[year].length} post{groupedByYear[year].length === 1 ? '' : 's'}
                    </div>
                </div>

                {groupedByYear[year].map((post) => (
                    <a href={getPostUrlBySlug(post.slug)}
                       aria-label={post.data.title}
                       class="group btn-plain !block h-10 w-full rounded-lg hover:text-[initial]">
                        <div class="flex flex-row justify-start items-center h-full">
                            <div class="w-[15%] md:w-[10%] transition text-sm text-right text-50">
                                {formatDateToYYYYMMDD(post.data.published).substring(5)}
                            </div>
                            <div class="w-[15%] md:w-[10%] relative dash-line h-full flex items-center">
                                <div class="transition-all mx-auto w-1 h-1 rounded group-hover:h-5
                                    bg-[oklch(0.5_0.05_var(--hue))] group-hover:bg-[var(--primary)]
                                    outline outline-4 z-50
                                    outline-[var(--card-bg)]
                                    group-hover:outline-[var(--btn-plain-bg-hover)]
                                    group-active:outline-[var(--btn-plain-bg-active)]"></div>
                            </div>
                            <div class="w-[70%] md:max-w-[65%] md:w-[65%] text-left font-bold
                                group-hover:translate-x-1 transition-all group-hover:text-[var(--primary)]
                                text-75 pr-8 whitespace-nowrap overflow-ellipsis overflow-hidden">
                                {post.data.title}
                            </div>
                            <div class="hidden md:block md:w-[15%] text-left text-sm transition
                                whitespace-nowrap overflow-ellipsis overflow-hidden text-30">
                                {post.data.tags.map(t => `#${t}`).join(' ')}
                            </div>
                        </div>
                    </a>
                ))}
            </div>
        ))}
    </div>
    </category-view-toggle>
    <script is:inline>
    class CategoryViewToggle extends HTMLElement {
        connectedCallback() {
            if (this.dataset.initialized === 'true') return;
            this.dataset.initialized = 'true';

            const btnCard = this.querySelector('[data-view="card"]');
            const btnList = this.querySelector('[data-view="list"]');
            const viewCard = this.querySelector('[data-panel="card"]');
            const viewList = this.querySelector('[data-panel="list"]');

            if (!btnCard || !btnList || !viewCard || !viewList) return;

            const activeStyle = 'color: var(--primary); background-color: var(--btn-plain-bg-hover);';
            const storage = sessionStorage;

            function setView(mode, animate = false) {
                const showPanel = mode === 'card' ? viewCard : viewList;
                const hidePanel = mode === 'card' ? viewList : viewCard;
                const activeBtn = mode === 'card' ? btnCard : btnList;
                const inactiveBtn = mode === 'card' ? btnList : btnCard;

                hidePanel?.classList.add('hidden');
                showPanel?.classList.remove('hidden');
                if (activeBtn) activeBtn.style.cssText = activeStyle;
                if (inactiveBtn) inactiveBtn.style.cssText = '';

                if (animate && showPanel) {
                    showPanel.style.animation = 'none';
                    void showPanel.offsetWidth;
                    showPanel.style.animation = '300ms fade-in-up forwards';
                }

                storage.setItem('category-view-mode', mode);
            }

            // Restore saved view mode
            const saved = storage.getItem('category-view-mode');
            if (saved === 'list') {
                setView('list');
            }

            btnCard.addEventListener('click', () => setView('card', true));
            btnList.addEventListener('click', () => setView('list', true));
        }
    }

    if (!customElements.get('category-view-toggle')) {
        customElements.define('category-view-toggle', CategoryViewToggle);
    }
</script>
</MainGridLayout>
